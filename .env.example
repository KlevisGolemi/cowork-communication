# ═══════════════════════════════════════════════════════════════
#  Webhook Queue — Configuration
#  Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════

# ── Domaine public (Traefik + Cloudflare DNS) ─────────────────
DOMAIN=your-domain.example.com

# ── Sécurité ──────────────────────────────────────────────────
# Clé secrète partagée entre n8n et Cowork
# Générer avec : openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_remplacer_par_une_cle_forte

# ── Serveur ───────────────────────────────────────────────────
PORT=3333

# ── Base de données SQLite ────────────────────────────────────
DB_PATH=/data/queue.db

# ── Rétention et nettoyage ────────────────────────────────────
# Durée de vie max d'un message non lu (en heures)
TTL_HOURS=48

# Fréquence du cleanup automatique (en minutes)
CLEANUP_INTERVAL_MIN=60

# ── MCP Server distant (optionnel — pour accès Claude) ────────
# Sous-domaine pointant vers l'IP VPS (DNS A record)
MCP_DOMAIN=mcp.your-domain.example.com

# Token embarqué dans l'URL du MCP : openssl rand -hex 16
MCP_TOKEN=CHANGE_ME_32_hex_chars_minimum
